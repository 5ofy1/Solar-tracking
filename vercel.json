<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solar Tracker Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Cairo:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050d1a;
    --panel: #0a1628;
    --border: #1a3a5c;
    --accent: #f59e0b;
    --accent2: #3b82f6;
    --green: #10b981;
    --red: #ef4444;
    --text: #e2e8f0;
    --sub: #64748b;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Starfield background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(245,158,11,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 80% 10%, rgba(59,130,246,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 50% 60%, rgba(255,255,255,0.2) 0%, transparent 100%),
      radial-gradient(1px 1px at 10% 80%, rgba(255,255,255,0.15) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 70%, rgba(255,255,255,0.2) 0%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 20px;
    position: relative;
    z-index: 1;
  }

  /* Header */
  header {
    text-align: center;
    padding: 30px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 30px;
  }

  .sun-icon {
    display: inline-block;
    width: 60px;
    height: 60px;
    margin-bottom: 12px;
    animation: spin 10s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  header h1 {
    font-family: 'Orbitron', monospace;
    font-size: 1.8rem;
    font-weight: 900;
    letter-spacing: 3px;
    background: linear-gradient(135deg, var(--accent), #fcd34d, var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
  }

  header p {
    color: var(--sub);
    font-size: 0.85rem;
    margin-top: 6px;
    letter-spacing: 1px;
  }

  /* Connection config */
  .config-box {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: flex-end;
  }

  .field {
    flex: 1;
    min-width: 180px;
  }

  label {
    display: block;
    font-size: 0.75rem;
    color: var(--sub);
    margin-bottom: 6px;
    letter-spacing: 1px;
  }

  input, select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text);
    font-family: 'Cairo', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
  }

  input:focus, select:focus {
    border-color: var(--accent);
  }

  .connect-btn {
    padding: 10px 28px;
    background: linear-gradient(135deg, var(--accent), #d97706);
    border: none;
    border-radius: 8px;
    color: #000;
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .connect-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(245,158,11,0.4);
  }

  /* Status badge */
  .status-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
  }

  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--red);
    flex-shrink: 0;
  }

  .status-dot.connected {
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .status-text { font-size: 0.85rem; color: var(--sub); }

  /* Main cards */
  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  @media (max-width: 600px) {
    .cards { grid-template-columns: 1fr; }
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s;
  }

  .card:hover { transform: translateY(-2px); }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
  }

  .card.voltage::before { background: linear-gradient(90deg, var(--accent), #fcd34d); }
  .card.current::before { background: linear-gradient(90deg, var(--accent2), #93c5fd); }

  .card-label {
    font-size: 0.75rem;
    letter-spacing: 2px;
    color: var(--sub);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .card-icon {
    position: absolute;
    top: 20px;
    left: 20px;
    font-size: 1.8rem;
    opacity: 0.15;
  }

  .card-value {
    font-family: 'Orbitron', monospace;
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
  }

  .card.voltage .card-value { color: var(--accent); }
  .card.current .card-value { color: var(--accent2); }

  .card-unit {
    font-family: 'Orbitron', monospace;
    font-size: 1rem;
    color: var(--sub);
    margin-top: 4px;
  }

  .card-extra {
    margin-top: 14px;
    font-size: 0.8rem;
    color: var(--sub);
    border-top: 1px solid var(--border);
    padding-top: 10px;
    display: flex;
    justify-content: space-between;
  }

  .card-extra span { color: var(--text); font-weight: 600; }

  /* Power card */
  .power-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .power-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(245,158,11,0.06) 0%, transparent 70%);
  }

  .power-label {
    font-size: 0.75rem;
    letter-spacing: 2px;
    color: var(--sub);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .power-value {
    font-family: 'Orbitron', monospace;
    font-size: 2.5rem;
    font-weight: 900;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Gauge bar */
  .gauge {
    margin-top: 16px;
  }

  .gauge-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: var(--sub);
    margin-bottom: 6px;
  }

  .gauge-track {
    height: 8px;
    background: var(--bg);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .gauge-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
  }

  .gauge-fill.volt { background: linear-gradient(90deg, var(--accent), #fcd34d); }
  .gauge-fill.amp { background: linear-gradient(90deg, var(--accent2), #93c5fd); }

  /* Chart */
  .chart-box {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    margin-bottom: 24px;
  }

  .chart-title {
    font-size: 0.8rem;
    letter-spacing: 2px;
    color: var(--sub);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .chart-legend { display: flex; gap: 16px; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 0.75rem; color: var(--sub); }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; }

  canvas { width: 100% !important; }

  /* Alert */
  .alert {
    padding: 12px 18px;
    border-radius: 8px;
    font-size: 0.85rem;
    margin-bottom: 16px;
    display: none;
    align-items: center;
    gap: 10px;
  }

  .alert.show { display: flex; }
  .alert.warn { background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.3); color: var(--accent); }
  .alert.err { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: var(--red); }

  /* Demo mode toggle */
  .demo-note {
    text-align: center;
    color: var(--sub);
    font-size: 0.78rem;
    margin-top: 10px;
    letter-spacing: 0.5px;
  }

  .demo-note a {
    color: var(--accent);
    cursor: pointer;
    text-decoration: none;
  }
</style>
</head>
<body>
<div class="container">
  <header>
    <svg class="sun-icon" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="30" cy="30" r="12" fill="#f59e0b"/>
      <g stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round">
        <line x1="30" y1="4" x2="30" y2="10"/>
        <line x1="30" y1="50" x2="30" y2="56"/>
        <line x1="4" y1="30" x2="10" y2="30"/>
        <line x1="50" y1="30" x2="56" y2="30"/>
        <line x1="11.51" y1="11.51" x2="15.75" y2="15.75"/>
        <line x1="44.25" y1="44.25" x2="48.49" y2="48.49"/>
        <line x1="48.49" y1="11.51" x2="44.25" y2="15.75"/>
        <line x1="15.75" y1="44.25" x2="11.51" y2="48.49"/>
      </g>
    </svg>
    <h1>SOLAR TRACKER</h1>
    <p>نظام متابعة الطاقة الشمسية — ESP32</p>
  </header>

  <!-- Config -->
  <div class="config-box">
    <div class="field">
      <label>عنوان ESP32 (IP)</label>
      <input id="espIp" type="text" placeholder="192.168.1.100" value="192.168.1.100">
    </div>
    <div class="field">
      <label>المسار (Endpoint)</label>
      <input id="espPath" type="text" placeholder="/data" value="/data">
    </div>
    <div class="field">
      <label>التحديث (ثانية)</label>
      <input id="interval" type="number" min="1" max="60" value="2">
    </div>
    <button class="connect-btn" onclick="toggleConnect()">اتصال</button>
  </div>

  <!-- Status -->
  <div class="status-row">
    <div class="status-dot" id="statusDot"></div>
    <span class="status-text" id="statusText">غير متصل — وضع العرض التجريبي نشط</span>
  </div>

  <!-- Alert -->
  <div class="alert" id="alertBox">
    <span id="alertIcon">⚠️</span>
    <span id="alertMsg"></span>
  </div>

  <!-- Main cards -->
  <div class="cards">
    <div class="card voltage">
      <div class="card-icon">⚡</div>
      <div class="card-label">الجهد الكهربائي</div>
      <div class="card-value" id="voltVal">--.-</div>
      <div class="card-unit">Volt</div>
      <div class="gauge" style="margin-top:14px">
        <div class="gauge-label"><span>0V</span><span id="voltMax">25V</span></div>
        <div class="gauge-track"><div class="gauge-fill volt" id="voltBar" style="width:0%"></div></div>
      </div>
      <div class="card-extra">
        <span>الحد الأدنى: <span id="voltMin">--</span>V</span>
        <span>الحد الأقصى: <span id="voltMaxVal">--</span>V</span>
      </div>
    </div>

    <div class="card current">
      <div class="card-icon">〜</div>
      <div class="card-label">التيار الكهربائي</div>
      <div class="card-value" id="currVal">--.-</div>
      <div class="card-unit">Ampere</div>
      <div class="gauge" style="margin-top:14px">
        <div class="gauge-label"><span>0A</span><span id="currMax">10A</span></div>
        <div class="gauge-track"><div class="gauge-fill amp" id="currBar" style="width:0%"></div></div>
      </div>
      <div class="card-extra">
        <span>الحد الأدنى: <span id="currMin">--</span>A</span>
        <span>الحد الأقصى: <span id="currMaxVal">--</span>A</span>
      </div>
    </div>
  </div>

  <!-- Power card -->
  <div class="power-card">
    <div class="power-label">القدرة الكهربائية الكلية</div>
    <div class="power-value" id="powerVal">--- W</div>
    <div style="color:var(--sub);font-size:0.8rem;margin-top:4px">P = V × I</div>
  </div>

  <!-- Chart -->
  <div class="chart-box">
    <div class="chart-title">
      <span>📈 سجل القراءات</span>
      <div class="chart-legend">
        <div class="legend-item"><div class="legend-dot" style="background:var(--accent)"></div>الجهد (V)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--accent2)"></div>التيار (A)</div>
      </div>
    </div>
    <canvas id="chart" height="160"></canvas>
  </div>

  <div class="demo-note">
    في وضع التجريبي، البيانات محاكاة. لربط ESP32 أدخل العنوان واضغط <strong>اتصال</strong>.<br>
    يجب أن يُعيد ESP32 بيانات JSON بالشكل: <a>{"voltage": 18.5, "current": 2.3}</a>
  </div>
</div>

<script>
// ---- Chart setup ----
const canvas = document.getElementById('chart');
const ctx = canvas.getContext('2d');

const MAX_POINTS = 60;
const history = { time: [], voltage: [], current: [] };

function drawChart() {
  const W = canvas.offsetWidth;
  const H = canvas.offsetHeight || 160;
  canvas.width = W * devicePixelRatio;
  canvas.height = H * devicePixelRatio;
  ctx.scale(devicePixelRatio, devicePixelRatio);

  ctx.clearRect(0, 0, W, H);

  if (history.voltage.length < 2) return;

  const pad = { top: 10, right: 10, bottom: 20, left: 10 };
  const cw = W - pad.left - pad.right;
  const ch = H - pad.top - pad.bottom;

  // Grid
  ctx.strokeStyle = 'rgba(255,255,255,0.04)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = pad.top + (ch / 4) * i;
    ctx.beginPath();
    ctx.moveTo(pad.left, y);
    ctx.lineTo(pad.left + cw, y);
    ctx.stroke();
  }

  const n = history.voltage.length;

  function drawLine(data, color, maxVal) {
    const grd = ctx.createLinearGradient(0, pad.top, 0, pad.top + ch);
    grd.addColorStop(0, color.replace(')', ', 0.3)').replace('rgb', 'rgba'));
    grd.addColorStop(1, color.replace(')', ', 0)').replace('rgb', 'rgba'));

    ctx.beginPath();
    for (let i = 0; i < n; i++) {
      const x = pad.left + (i / (MAX_POINTS - 1)) * cw;
      const y = pad.top + ch - (data[i] / maxVal) * ch;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.stroke();

    // fill
    ctx.lineTo(pad.left + ((n-1) / (MAX_POINTS - 1)) * cw, pad.top + ch);
    ctx.lineTo(pad.left, pad.top + ch);
    ctx.closePath();
    ctx.fillStyle = grd;
    ctx.fill();
  }

  const maxV = Math.max(25, ...history.voltage) * 1.1;
  const maxA = Math.max(10, ...history.current) * 1.1;

  // Normalize current to voltage scale for visual
  const normalizedCurr = history.current.map(a => (a / maxA) * maxV);

  drawLine(history.voltage, '#f59e0b', maxV);
  drawLine(normalizedCurr, '#3b82f6', maxV);
}

// ---- Stats tracking ----
let stats = { voltMin: Infinity, voltMax: -Infinity, currMin: Infinity, currMax: -Infinity };

function updateDisplay(voltage, current) {
  const power = voltage * current;

  document.getElementById('voltVal').textContent = voltage.toFixed(1);
  document.getElementById('currVal').textContent = current.toFixed(2);
  document.getElementById('powerVal').textContent = power.toFixed(1) + ' W';

  // Gauges
  const voltMax = parseFloat(document.getElementById('voltMax').textContent);
  const currMax = parseFloat(document.getElementById('currMax').textContent);
  document.getElementById('voltBar').style.width = Math.min(100, (voltage / voltMax) * 100) + '%';
  document.getElementById('currBar').style.width = Math.min(100, (current / currMax) * 100) + '%';

  // Stats
  stats.voltMin = Math.min(stats.voltMin, voltage);
  stats.voltMax = Math.max(stats.voltMax, voltage);
  stats.currMin = Math.min(stats.currMin, current);
  stats.currMax = Math.max(stats.currMax, current);
  document.getElementById('voltMin').textContent = stats.voltMin.toFixed(1);
  document.getElementById('voltMaxVal').textContent = stats.voltMax.toFixed(1);
  document.getElementById('currMin').textContent = stats.currMin.toFixed(2);
  document.getElementById('currMaxVal').textContent = stats.currMax.toFixed(2);

  // History
  const now = new Date().toLocaleTimeString('ar-IQ');
  history.time.push(now);
  history.voltage.push(voltage);
  history.current.push(current);
  if (history.time.length > MAX_POINTS) {
    history.time.shift(); history.voltage.shift(); history.current.shift();
  }

  drawChart();

  // Alerts
  const alertBox = document.getElementById('alertBox');
  if (voltage > 24) {
    alertBox.className = 'alert show err';
    document.getElementById('alertMsg').textContent = '⚠️ تحذير: الجهد مرتفع جداً! (' + voltage.toFixed(1) + 'V)';
  } else if (current > 8) {
    alertBox.className = 'alert show warn';
    document.getElementById('alertMsg').textContent = '⚡ تنبيه: التيار مرتفع (' + current.toFixed(2) + 'A)';
  } else {
    alertBox.className = 'alert';
  }
}

// ---- Demo simulation ----
let demoTimer = null;
let demoPhase = 0;

function startDemo() {
  demoTimer = setInterval(() => {
    demoPhase += 0.05;
    // Simulate a solar tracker curve - rises and falls
    const voltage = 12 + 8 * Math.abs(Math.sin(demoPhase * 0.3)) + (Math.random() - 0.5) * 0.5;
    const current = 1 + 4 * Math.abs(Math.sin(demoPhase * 0.3)) + (Math.random() - 0.5) * 0.2;
    updateDisplay(voltage, current);
  }, 1000);
}

function stopDemo() {
  clearInterval(demoTimer);
  demoTimer = null;
}

// ---- Real ESP32 connection ----
let fetchTimer = null;
let isConnected = false;

async function fetchESP() {
  const ip = document.getElementById('espIp').value.trim();
  const path = document.getElementById('espPath').value.trim();
  const url = 'http://' + ip + path;

  try {
    const res = await fetch(url, { signal: AbortSignal.timeout(3000) });
    const data = await res.json();
    
    const voltage = parseFloat(data.voltage ?? data.volt ?? data.v ?? 0);
    const current = parseFloat(data.current ?? data.curr ?? data.i ?? data.ampere ?? 0);

    if (!isConnected) {
      isConnected = true;
      document.getElementById('statusDot').classList.add('connected');
      document.getElementById('statusText').textContent = 'متصل بـ ESP32 على ' + ip;
      stopDemo();
    }

    updateDisplay(voltage, current);
  } catch (e) {
    if (isConnected) {
      isConnected = false;
      document.getElementById('statusDot').classList.remove('connected');
      document.getElementById('statusText').textContent = 'انقطع الاتصال — إعادة المحاولة...';
      startDemo();
    }
  }
}

let fetchActive = false;

function toggleConnect() {
  const btn = document.querySelector('.connect-btn');
  if (!fetchActive) {
    fetchActive = true;
    btn.textContent = 'قطع الاتصال';
    stopDemo();
    const sec = parseInt(document.getElementById('interval').value) * 1000 || 2000;
    fetchESP();
    fetchTimer = setInterval(fetchESP, sec);
  } else {
    fetchActive = false;
    isConnected = false;
    clearInterval(fetchTimer);
    btn.textContent = 'اتصال';
    document.getElementById('statusDot').classList.remove('connected');
    document.getElementById('statusText').textContent = 'غير متصل — وضع العرض التجريبي نشط';
    startDemo();
  }
}

// ---- Init ----
startDemo();
window.addEventListener('resize', drawChart);
</script>
</body>
</html>
